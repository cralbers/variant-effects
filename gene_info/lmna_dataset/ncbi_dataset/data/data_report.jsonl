{"geneId":"4000","symbol":"LMNA","description":"lamin A/C","taxId":"9606","taxname":"Homo sapiens","type":"PROTEIN_CODING","orientation":"plus","commonName":"human","chromosomes":["1"],"nomenclatureAuthority":{"authority":"HGNC","identifier":"HGNC:6636"},"swissProtAccessions":["P02545"],"ensemblGeneIds":["ENSG00000160789"],"omimIds":["150330"],"synonyms":["FPL","IDC","LFP","CDDC","EMD2","FPLD","HGPS","LDP1","LMN1","LMNC","MADA","PRO1","CDCD1","CMD1A","FPLD2","LMNL1","CMT2B1","LGMD1B"],"referenceStandards":[{"geneRange":{"accessionVersion":"NG_008692.2","range":[{"begin":"4974","end":"62517","orientation":"plus"}]},"type":"REFSEQ_GENE"}],"annotations":[{"assemblyAccession":"GCF_000001405.40","assemblyName":"GRCh38.p14","annotationName":"GCF_000001405.40-RS_2025_08","annotationReleaseDate":"2025-08-01","genomicLocations":[{"genomicAccessionVersion":"NC_000001.11","sequenceName":"1","genomicRange":{"begin":"156082573","end":"156140081","orientation":"plus"}}]},{"assemblyAccession":"GCF_009914755.1","assemblyName":"T2T-CHM13v2.0","annotationName":"GCF_009914755.1-RS_2025_08","annotationReleaseDate":"2025-08-01","genomicLocations":[{"genomicAccessionVersion":"NC_060925.1","sequenceName":"1","genomicRange":{"begin":"155221038","end":"155278530","orientation":"plus"}}]}],"transcriptCount":28,"proteinCount":28,"transcriptTypeCounts":[{"type":"PROTEIN_CODING","count":28}],"geneGroups":[{"id":"4000","method":"NCBI Ortholog"}],"summary":[{"description":"The protein encoded by this gene is part of the nuclear lamina, a two-dimensional matrix of proteins located next to the inner nuclear membrane. The lamin family of proteins make up the matrix and are highly conserved in evolution. During mitosis, the lamina matrix is reversibly disassembled as the lamin proteins are phosphorylated. Lamin proteins are thought to be involved in nuclear stability, chromatin structure and gene expression. Vertebrate lamins consist of two types, A and B. Alternative splicing results in multiple transcript variants. Mutations in this gene lead to several diseases: Emery-Dreifuss muscular dystrophy, familial partial lipodystrophy, limb girdle muscular dystrophy, dilated cardiomyopathy, Charcot-Marie-Tooth disease, and Hutchinson-Gilford progeria syndrome. [provided by RefSeq, May 2022]"}],"geneOntology":{"assignedBy":"GOA","molecularFunctions":[{"name":"identical protein binding","goId":"GO:0042802","evidenceCode":"IPI","qualifier":"enables","reference":{"pmids":["25910212"]}},{"name":"protein binding","goId":"GO:0005515","evidenceCode":"IPI","qualifier":"enables","reference":{"pmids":["10381623","10514485","10727209","11313760","11587540","11801724","14597414","15140953","15161933","15671068","16247757","19323649","19933576","20000738","20467437","20580717","20618440","21346760","21418524","21949239","21988832","21993218","22399800","22555292","23539603","23658700","23977161","24375709","24981860","25399868","25416956","25910212","26524528","29568061","29997244","30021884","30488537","31467278","31515488","31548606","32296183","32814053","33961781","35271311","35311970","37398436"]}},{"name":"structural constituent of cytoskeleton","goId":"GO:0005200","evidenceCode":"IBA","qualifier":"enables"},{"name":"structural constituent of cytoskeleton","goId":"GO:0005200","evidenceCode":"IDA","qualifier":"enables","reference":{"pmids":["31548606"]}},{"name":"structural constituent of cytoskeleton","goId":"GO:0005200","evidenceCode":"IMP","qualifier":"enables","reference":{"pmids":["23658700"]}},{"name":"structural constituent of nuclear lamina","goId":"GO:0160123","evidenceCode":"IDA","qualifier":"enables","reference":{"pmids":["2188730","2344612","24741066","37788673","37832547"]}},{"name":"structural constituent of nuclear lamina","goId":"GO:0160123","evidenceCode":"IEA","qualifier":"enables"},{"name":"structural molecule activity","goId":"GO:0005198","evidenceCode":"TAS","qualifier":"enables","reference":{"pmids":["3453101","8344919"]}}],"biologicalProcesses":[{"name